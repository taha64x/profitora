# ─── Datenbank ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/hotel_audit_ai"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="aendern-sie-diesen-schluessel-min-32-zeichen-lang"
JWT_EXPIRES_IN="7d"

# ─── KI-Anbieter (nur einen aktivieren) ──────────────────────────────────────
AI_PROVIDER="anthropic"   # "anthropic" oder "openai"
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ─── Datei-Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="20"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Zukünftig: S3 / Cloudflare R2 ───────────────────────────────────────────
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# ─── Stripe (Zahlungen) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (im Stripe Dashboard anlegen)
STRIPE_PRICE_STANDARD="price_..."
STRIPE_PRICE_TIEFENANALYSE="price_..."
STRIPE_PRICE_KOMPLETT="price_..."

# ─── E-Mail (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Profitora <noreply@profitora.de>"

# ─── Zukünftig: S3 / Cloudflare R2 ───────────────────────────────────────────
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
