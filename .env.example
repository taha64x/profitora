# ─── Datenbank ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/hotel_audit_ai"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="aendern-sie-diesen-schluessel-min-32-zeichen-lang"
JWT_EXPIRES_IN="7d"

# ─── KI-Anbieter (nur einen aktivieren) ──────────────────────────────────────
AI_PROVIDER="anthropic"   # "anthropic" oder "openai"
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ─── Datei-Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"          # nur lokale Entwicklung (Fallback ohne Blob-Token)
MAX_FILE_SIZE_MB="20"
# Produktion: Vercel Blob Storage. Token wird von Vercel automatisch gesetzt,
# wenn ein Blob-Store mit dem Projekt verbunden ist (Vercel Dashboard → Storage).
BLOB_READ_WRITE_TOKEN=""

# ─── Python-Analyse-Funktion ─────────────────────────────────────────────────
# Auf Vercel ruft die App die separate Python-Serverless-Funktion /api/py/analyze
# per HTTP auf. URL wird i.d.R. aus NEXT_PUBLIC_APP_URL/VERCEL_URL abgeleitet;
# nur überschreiben, falls die Funktion anderswo liegt:
# PYTHON_ANALYZE_URL="https://profitora.de/api/py/analyze"
# PFLICHT in Produktion: gleicher Geheim-Token in App-Env UND Python-Funktion-Env.
# Ohne diesen Token verweigert die Python-Funktion JEDE Anfrage (fail-closed).
# Generieren z.B. mit: openssl rand -hex 32
PY_INTERNAL_TOKEN=""
# SSRF-Schutz: erlaubter Host-Suffix für Datei-Downloads (Default = Vercel Blob).
# BLOB_ALLOWED_HOST_SUFFIX=".public.blob.vercel-storage.com"
# Lokal: Pfad zu installiertem Chrome für PDF-Erzeugung (Default = macOS-Standard)
# LOCAL_CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Stripe (Zahlungen) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (im Stripe Dashboard anlegen)
STRIPE_PRICE_STANDARD="price_..."
STRIPE_PRICE_TIEFENANALYSE="price_..."
STRIPE_PRICE_KOMPLETT="price_..."

# ─── E-Mail (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Profitora <noreply@profitora.de>"
