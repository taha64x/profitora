generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Verbindungs-URLs: siehe prisma.config.ts (Prisma 7).
  // Laufzeit: gepoolte DATABASE_URL. Schema-Push/Migrationen: direkte Verbindung.
}

// ─── Nutzer ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  tokenVersion Int      @default(0) // Session-Invalidierung: +1 bei Passwort-Reset
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships OrganizationMember[]
  uploads     Upload[]
  reports     AnalysisReport[]
  resetTokens PasswordResetToken[]
}

// ─── Organisation / Unternehmen ───────────────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  businessType String   @default("other")   // z.B. "hotel", "restaurant", "retail", "medical", etc.
  unitCount    Int?     @map("roomCount")    // Zimmer / Sitzplätze / Behandlungsräume / etc.
  unitLabel    String?                       // "Zimmer", "Sitzplätze", "Behandlungsplätze", etc.
  city         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members        OrganizationMember[]
  uploads        Upload[]
  reports        AnalysisReport[]
  expenses       Expense[]
  revenues       Revenue[]
  subscription   Subscription?
  settings       Settings?
  monthlyTargets MonthlyTarget[]
  areas            Area[]
  recurringEntries RecurringEntry[]
  alertRules       AlertRule[]
  alertEvents      AlertEvent[]
  employees        Employee[]
  shifts           Shift[]
  shiftTemplates   ShiftTemplate[]
  absences         Absence[]
  planShareToken   PlanShareToken?
  measures         Measure[]
}

model OrganizationMember {
  id             String     @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Datei-Uploads ────────────────────────────────────────────────────────────

model Upload {
  id             String         @id @default(cuid())
  filename       String
  originalName   String
  category       UploadCategory
  mimeType       String
  fileSize       Int
  storagePath    String
  organizationId String
  uploadedById   String
  columnMapping  Json?
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime       @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User           @relation(fields: [uploadedById], references: [id])
  reportItems  ReportUpload[]
}

enum UploadCategory {
  EMPLOYEE_HOURS
  REVENUE
  EXPENSES
  BOOKINGS
  ROOM_CATEGORIES
  OTHER
}

// ─── Analyseberichte ──────────────────────────────────────────────────────────

model AnalysisReport {
  id             String         @id @default(cuid())
  title          String
  organizationId String
  createdById    String
  status         AnalysisStatus @default(PENDING)
  htmlContent    String?        @db.Text
  metadata       Json?
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User           @relation(fields: [createdById], references: [id])
  uploads      ReportUpload[]
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ReportUpload {
  reportId String
  uploadId String

  report AnalysisReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  upload Upload         @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@id([reportId, uploadId])
}

// ─── Ausgaben ────────────────────────────────────────────────────────────────

model Expense {
  id                  String   @id @default(cuid())
  organizationId      String
  createdById         String
  date                DateTime
  category            String
  description         String
  amount              Float
  currency            String   @default("EUR")
  paymentMethod       String?
  vendor              String?
  areaId              String?
  vatRate             Int?      // 0 | 7 | 19
  receiptPath         String?   // Blob: receipts/<orgId>/<uuid>.<ext>
  receiptName         String?
  importHash          String?   // Duplikat-Schutz CSV-Import
  recurringEntryId    String?   // Herkunft: Cron-generiert aus RecurringEntry
  isRecurring         Boolean  @default(false)
  recurrenceInterval  String?  // monthly | quarterly | yearly
  fileId              String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  area         Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
}

// ─── Einnahmen ────────────────────────────────────────────────────────────────

model Revenue {
  id                  String   @id @default(cuid())
  organizationId      String
  createdById         String
  date                DateTime
  category            String
  description         String
  amount              Float
  currency            String   @default("EUR")
  customerOrSource    String?
  paymentStatus       String   @default("paid") // paid | open | cancelled
  areaId              String?
  vatRate             Int?      // 0 | 7 | 19
  receiptPath         String?   // Blob: receipts/<orgId>/<uuid>.<ext>
  receiptName         String?
  importHash          String?   // Duplikat-Schutz CSV-Import
  recurringEntryId    String?   // Herkunft: Cron-generiert aus RecurringEntry
  isRecurring         Boolean  @default(false)
  recurrenceInterval  String?
  fileId              String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  area         Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
}

// ─── Abonnement ───────────────────────────────────────────────────────────────

model Subscription {
  id                     String    @id @default(cuid())
  organizationId         String    @unique
  planName               String    @default("free") // free | starter | business | premium; Altbestand: 'premium' OHNE stripeSubscriptionId = Legacy-Credit-Käufer (zählt als free)
  status                 String    @default("active") // active | cancelled | past_due | trialing
  // Bezahlmodell: jede Analyse verbraucht 1 Credit; Credits werden als
  // Einzelanalyse oder Paket (3er/5er) gekauft und verfallen nicht.
  analysisCredits        Int       @default(0)
  monthlyAnalysisLimit   Int       @default(1)
  usedAnalysesThisMonth  Int       @default(0)
  assistantMsgsThisMonth Int       @default(0)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  billingInterval        String?   // 'month' | 'year' – nur bei aktivem Abo gesetzt
  lastIncludedAnalysisAt DateTime? // Premium: letzte genutzte Quartals-Inklusivanalyse
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Stripe-Käufe (Idempotenz-Schutz) ─────────────────────────────────────────
// Stripe stellt Webhooks mehrfach zu; die unique Session-ID stellt sicher,
// dass Credits pro Checkout genau einmal gutgeschrieben werden.

model StripePurchase {
  id              String   @id @default(cuid())
  organizationId  String
  stripeSessionId String   @unique
  pack            String   // single | triple | five
  credits         Int
  amountCents     Int
  createdAt       DateTime @default(now())

  // Rechnungsdaten (§ 14 Abs. 4 UStG): fortlaufende Nummer + Snapshot des
  // Rechnungsempfängers aus Stripe customer_details zum Kaufzeitpunkt.
  // Nullable, damit Alt-Käufe ohne diese Daten gültig bleiben.
  invoiceNumber String? @unique // z. B. PA-2026-0001
  buyerName     String? // Vor- und Nachname (Karteninhaber / Rechnungsadresse)
  buyerCompany  String? // Unternehmensname (Organization zum Kaufzeitpunkt)
  addressLine1  String?
  addressLine2  String?
  postalCode    String?
  city          String?
  country       String? // ISO-Code aus Stripe, z. B. "DE"
  customerEmail String?
}

// ─── Rechnungsnummernkreis ────────────────────────────────────────────────────
// § 14 Abs. 4 Nr. 4 UStG verlangt eine fortlaufende, einmalige Rechnungsnummer.
// Pro Jahr ein Zähler; Vergabe atomar in der Webhook-Transaktion.

model InvoiceCounter {
  year       Int @id
  lastNumber Int @default(0)
}

// ─── Einstellungen ────────────────────────────────────────────────────────────

model Settings {
  id                     String   @id @default(cuid())
  organizationId         String   @unique
  language               String   @default("de")
  currency               String   @default("EUR")
  emailNotifications     Boolean  @default(true)
  monthlyReminder        Boolean  @default(true)
  defaultAnalysisPeriod  String   @default("last_month") // last_month | last_quarter | last_year | custom
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Monatliche Ziele (Profitabilitäts-Tracking) ─────────────────────────────

model MonthlyTarget {
  id             String   @id @default(cuid())
  organizationId String
  year           Int
  month          Int      // 1–12
  revenueTarget  Float?
  expenseTarget  Float?
  note           String?
  sourceReportId String?  // aus welchem Analysebericht abgeleitet
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, year, month])
}

// ─── Analyseanfragen (neues Universal-Modell) ─────────────────────────────────

model AnalysisRequest {
  id                  String   @id @default(cuid())
  companyName         String?
  industry            String?
  analysisTypes       String[] // ["kosten", "mitarbeiter", "buchhaltung", "prozess", "branche", "komplett"]
  accuracyLevel       String   @default("standard") // schnellcheck | standard | tiefenanalyse | komplett
  inputMethod         String   @default("questionnaire") // upload | questionnaire | hybrid
  goals               String[] // ["kosten_senken", "gewinn_steigern", ...]
  questionnaireData   Json?    // alle Fragebogen-Antworten strukturiert
  uploadedFiles       String[] // Dateipfade
  consentConfirmed    Boolean  @default(false)
  privacyConfirmed    Boolean  @default(false)
  uploadAuthConfirmed Boolean  @default(false)
  status              String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  reportContent       String?  @db.Text
  organizationId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Bereiche (Finanzen + später Schichtplan) ────────────────────────────────

model Area {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     Expense[]
  revenues     Revenue[]
  shifts       Shift[]

  @@unique([organizationId, name])
}

// ─── Wiederkehrende Posten (Cron erzeugt Einträge) ───────────────────────────

model RecurringEntry {
  id             String    @id @default(cuid())
  organizationId String
  kind           String    // INCOME | EXPENSE
  amount         Float
  category       String
  areaId         String?
  vatRate        Int?
  vendor         String?   // EXPENSE: Lieferant · INCOME: Kunde/Quelle
  description    String
  interval       String    // monthly | quarterly | yearly
  nextRun        DateTime
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── KPI-Alerts ───────────────────────────────────────────────────────────────

model AlertRule {
  id             String    @id @default(cuid())
  organizationId String
  metric         String    // laborCostRatio | goodsCostRatio | netMarginPercent
  threshold      Float
  direction      String    // ABOVE | BELOW (wann feuern)
  active         Boolean   @default(true)
  lastFiredAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metric])
}

model AlertEvent {
  id             String   @id @default(cuid())
  organizationId String
  metric         String
  value          Float
  threshold      Float
  message        String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// ─── Team: Mitarbeiter, Schichten, Abwesenheiten (Phase 3) ───────────────────
// Chef pflegt alles — keine Mitarbeiter-Logins (V2). Zeiten als Minuten seit
// 0:00 (startMin/endMin, 0–1440); Nachtschichten über Mitternacht = V2.

model Employee {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  position           String?
  email              String?
  phone              String?
  address            String?
  hourlyWageCents    Int?
  monthlySalaryCents Int?
  weeklyHours        Float?
  vacationDaysPerYear Int?
  defaultAreaId      String?
  color              String   @default("#0E1A33")
  active             Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shifts       Shift[]
  absences     Absence[]
}

model Shift {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  date           DateTime // Tag (UTC-Mitternacht)
  startMin       Int      // Minuten seit 0:00
  endMin         Int      // > startMin, max 1440
  areaId         String?
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  area         Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)

  @@index([organizationId, date])
}

model ShiftTemplate {
  id             String  @id @default(cuid())
  organizationId String
  label          String
  startMin       Int
  endMin         Int
  areaId         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Absence {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  type           String   // VACATION | SICK | OFF
  startDate      DateTime
  endDate        DateTime
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId])
}

// Öffentlicher Read-only-Link auf den Wochenplan (Mitarbeiter ohne Login)
model PlanShareToken {
  id             String  @id @default(cuid())
  organizationId String  @unique
  token          String  @unique
  active         Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Maßnahmen-Tracker (Phase 4) ─────────────────────────────────────────────
// Empfehlungen aus Analysen werden Maßnahmen; die Folge-Analyse bewertet die
// Wirkung umgesetzter Maßnahmen anhand der Zahlen (Retention-Kern, Spec §5.2).

model Measure {
  id                   String    @id @default(cuid())
  organizationId       String
  reportId             String?
  title                String
  description          String?
  potentialSavingsCents Int?
  status               String    @default("OPEN") // OPEN | IMPLEMENTED | DISCARDED
  implementedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

// ─── Passwort-Reset (Auth-UX) ────────────────────────────────────────────────
// Es wird nur der SHA-256-Hash des Tokens gespeichert — der Klartext-Token
// existiert ausschließlich im E-Mail-Link (60 Minuten gültig, einmalig).

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
